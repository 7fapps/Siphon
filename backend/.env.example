# Siphon — Complete Environment Configuration

# App
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# Paths
TEMP_DOWNLOAD_DIR=./temp/downloads
DATABASE_URL=sqlite:///./siphon.db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_CONCURRENCY=2

# Rate Limiting
RATE_LIMIT_PROBE=10/minute
RATE_LIMIT_DOWNLOAD=5/minute
RATE_LIMIT_STATUS=60/minute

# Proxy
# Single proxy:
# PROXY_URL=http://user:pass@proxy:8080
# Multiple proxies for rotation (comma-separated):
# PROXY_URLS=http://proxy1:8080,http://proxy2:8080
# PROXY_ROTATION_STRATEGY=round_robin

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# yt-dlp
YTDLP_TIMEOUT=120
YTDLP_MAX_FILESIZE_MB=2048
# Multiple user agents for rotation (comma-separated):
# YTDLP_USER_AGENTS=Mozilla/5.0...,Mozilla/5.0...

# Cleanup
MAX_FILE_AGE_MINUTES=30
CLEANUP_INTERVAL_MINUTES=10

# Security
# API_KEY=your-api-key-here
# ADMIN_TOKEN=your-admin-secret-token

# Features
ENABLE_BATCH=true
ENABLE_AUDIO_ONLY=true
ENABLE_WEBSOCKET=true
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_ANALYTICS=true
ENABLE_PROXY_ROTATION=false

# WebSocket
WEBSOCKET_HEARTBEAT_INTERVAL=30
